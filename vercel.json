{
  "version": 2,
  "builds": [
    {
      "src": "server/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/cron/mining.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/cron/mining",
      "dest": "api/cron/mining.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "server/server.js"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/mining",
      "schedule": "0 0,12 * * 1-5"
    }
  ]
}
