{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "server/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/server.js"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "server/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1",
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/admin/(.*)",
      "dest": "admin/index.html"
    },
    {
      "src": "/.*",
      "dest": "index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/mining",
      "schedule": "0 0,12 * * 1-5"
    }
  ]
}